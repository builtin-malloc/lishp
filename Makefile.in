###############################################################################
#                                    PATHS                                    #
###############################################################################

LIBSRC := $(wildcard @SRCDIR@/lishp*.c)
LIBOBJ := $(LIBSRC:@SRCDIR@/%.c=@OBJDIR@/%.o)
LIBDEP := $(LIBOBJ:.o=.d)
LIB    := @BINDIR@/liblishp.a

BINSRC := @SRCDIR@/main.c @SRCDIR@/repl.c
BINOBJ := $(BINSRC:@SRCDIR@/%.c=@OBJDIR@/%.o)
BINDEP := $(BINOBJ:.o=.d)
BIN    := @BINDIR@/lishp

TESTSRC := $(wildcard @TESTDIR@/*.c)
TESTOBJ := $(TESTSRC:@TESTDIR@/%.c=@OBJDIR@/%.o)
TESTDEP := $(TESTOBJ:.o=.d)
TEST    := @BINDIR@/test_lishp

###############################################################################
#                                   TARGETS                                   #
###############################################################################

# BUILD #######################################################################

.PHONY: build

build: $(BIN) $(TEST)

$(BIN): $(BINOBJ) $(LIB)
	@CCLD@ -o $@ $(filter %.o,$^) @LDFLAGS@ -llishp
$(TEST): $(TESTOBJ) $(LIB)
	@CCLD@ -o $@ $(filter %.o,$^) @LDFLAGS@ -llishp
$(LIB): $(LIBOBJ)
	@AR@ @ARFLAGS@ $@ $(filter %.o,$^)

$(BINOBJ) $(LIBOBJ): @OBJDIR@/%.o: @SRCDIR@/%.c
	@CC@ -o $@ -c $< @CFLAGS@
$(TESTOBJ): @OBJDIR@/%.o: @TESTDIR@/%.c
	@CC@ -o $@ -c $< @CFLAGS@

-include $(LIBDEP)
-include $(BINDEP)
-include $(TESTDEP)

# TEST ########################################################################

.PHONY: test

test: $(TEST)
	$<

# CLEAN #######################################################################

.PHONY: clean distclean

clean:
	rm -f $(BIN)
	rm -f $(BINOBJ)
	rm -f $(BINDEP)
	rm -f $(LIB)
	rm -f $(LIBOBJ)
	rm -f $(LIBDEP)
	rm -f $(TEST)
	rm -f $(TESTOBJ)
	rm -f $(TESTDEP)

distclean:
	rm -rf @BINDIR@
	rm -rf @OBJDIR@
	rm -f @MAKEFILE@
	rm -f @CLANGD@

# CONFIGURE ###################################################################

%: Makefile
Makefile: Makefile.in configure
	./configure

